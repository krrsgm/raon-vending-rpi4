{
  "_comment": "RAON Vending Machine Configuration - Raspberry Pi 4",
  "currency_symbol": "₱",
  "always_fullscreen": true,
  "allow_decorations_for_admin": false,
  "rotate_display": "normal",
  
  "esp32_host": "192.168.4.1",
  
  "coin_hoppers": {
    "one_peso": {
      "motor_pin": 24,
      "sensor_pin": 26
    },
    "five_peso": {
      "motor_pin": 25,
      "sensor_pin": 27
    }
  },
  
  "hardware": {
    "coin_acceptor": {
      "enabled": true,
      "gpio_pin": 17,
      "debounce_ms": 50
    },
    "bill_acceptor": {
      "enabled": true,
      "serial_port": "/dev/ttyACM0",
      "baudrate": 115200,
      "proxy_via_esp32": true,
      "notes": "If using Arduino Uno over USB, /dev/ttyACM0 is typical. If using GPIO UART, set serial_port to /dev/serial0 and disable USB serial."
    },
    "dht11_sensors": {
      "components_area": {
        "enabled": true,
        "gpio_pin": 4
      },
      "payment_area": {
        "enabled": true,
        "gpio_pin": 17
      }
    }
  }
}
